# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# Data (raw is gitignored, processed splits regenerated)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# MLflow local tracking
mlruns/*
!mlruns/.gitkeep
mlartifacts/
reports/*
!reports/*.gitkeep
# Serialized models / preprocessors (root only — do not use models/ or src/models/ is excluded)
/models/
*.joblib
*.pkl

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
screenshots/*

# Notebooks
.ipynb_checkpoints/

# IDE / OS
.idea/
.vscode/
.DS_Store

# Docker
*.pid

# Screenshots keep dir only, ignore large binaries optionally kept for report
